# ═══════════════════════════════════════════════════════════════
#  ENVIRONMENT VARIABLES — Copy this file to .env.local
#  and fill in the values you need.
# ═══════════════════════════════════════════════════════════════

# ─── Image Hosting (optional) ─────────────────────────────────
# If you use S3 / CloudFront / any CDN for your profile image,
# set the base URL here. The app expects an /images/ folder.
# Leave empty to fall back to /favicon.svg locally.
NEXT_PUBLIC_S3_BASE_URL=

# ─── Google Analytics (optional) ──────────────────────────────
# Set your GA4 Measurement ID (G-XXXXXXXXXX) to enable tracking.
# Leave empty to disable Google Analytics entirely.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ─── Sentry (optional) ────────────────────────────────────────
# Used for error tracking in production. Leave empty to disable.
SENTRY_DSN=

# ─── GitHub Pages / Static Export (optional) ───────────────────
# If deploying to GitHub Pages with a repo sub-path, set this.
# Example: /my-repo-name
NEXT_PUBLIC_BASE_PATH=

# ─── General ───────────────────────────────────────────────────
NODE_ENV=development
